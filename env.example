# Supabase Configuration (REQUIRED)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ALTCHA CAPTCHA Configuration (REQUIRED - for spam protection)
# Generate a secure 64-byte key: openssl rand -hex 32
ALTCHA_HMAC_KEY=your_64_byte_hmac_key_here

# Email Configuration (REQUIRED - for booking confirmations)
VITE_EMAIL_API_URL=/.netlify/functions/send-email
VITE_EMAIL_FROM=noreply@hydrogenro.com

# Hostinger SMTP Configuration (for serverless function)
HOSTINGER_EMAIL_USER=your-email@hydrogenro.com
HOSTINGER_EMAIL_PASS=your-email-password

# Google Maps API (OPTIONAL - for location services)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Cloudinary Configuration (OPTIONAL - for image uploads)
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset
VITE_CLOUDINARY_API_KEY=your_cloudinary_api_key

# Secondary Cloudinary Configuration (OPTIONAL - for optimized/temporary images)
# Use this account for images that don't need to be kept long-term but are optimized
VITE_CLOUDINARY_SECONDARY_CLOUD_NAME=your_secondary_cloudinary_cloud_name
VITE_CLOUDINARY_SECONDARY_UPLOAD_PRESET=your_secondary_cloudinary_upload_preset
VITE_CLOUDINARY_SECONDARY_API_KEY=your_secondary_cloudinary_api_key

# Cashfree Payment Gateway Configuration (REQUIRED for payments)
VITE_CASHFREE_APP_ID=your_cashfree_app_id
VITE_CASHFREE_SECRET_KEY=your_cashfree_secret_key
VITE_CASHFREE_ENVIRONMENT=sandbox
VITE_CASHFREE_RETURN_URL=http://localhost:5173/payment/success
VITE_CASHFREE_NOTIFY_URL=http://localhost:5173/payment/webhook

# CORS Configuration (REQUIRED - for API security)
# Comma-separated list of allowed origins for serverless functions
# Localhost origins are automatically included for development
ALLOWED_ORIGINS=https://hydrogenro.com,https://www.hydrogenro.com