# Supabase Configuration (REQUIRED)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Email Configuration (REQUIRED - for booking confirmations)
VITE_EMAIL_API_URL=/.netlify/functions/send-email
VITE_EMAIL_FROM=noreply@hydrogenro.com

# Hostinger SMTP Configuration (for serverless function)
HOSTINGER_EMAIL_USER=your-email@hydrogenro.com
HOSTINGER_EMAIL_PASS=your-email-password

# Google Maps API (OPTIONAL - for location services)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Cloudinary Configuration (OPTIONAL - for image uploads)
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset
VITE_CLOUDINARY_API_KEY=your_cloudinary_api_key