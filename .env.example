# =============================================================================
# Copy to .env and fill in values. Use the SAME names in Netlify dashboard.
# =============================================================================

# --- Supabase (required) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Cloudinary (uploads in browser; delete via Netlify function) ---
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset
VITE_CLOUDINARY_API_KEY=your-api-key
# For photo DELETE: set on Netlify (server). Optional locally if you use netlify dev.
CLOUDINARY_API_SECRET=your-api-secret

# Optional: secondary Cloudinary account (e.g. payment/bill images)
# VITE_CLOUDINARY_SECONDARY_CLOUD_NAME=
# VITE_CLOUDINARY_SECONDARY_UPLOAD_PRESET=
# VITE_CLOUDINARY_SECONDARY_API_KEY=
# CLOUDINARY_SECONDARY_API_SECRET=

# --- Google Maps (optional; maps/places) ---
# VITE_GOOGLE_MAPS_API_KEY=

# --- Email (Netlify function send-email) ---
# VITE_EMAIL_API_URL=/.netlify/functions/send-email
# VITE_EMAIL_FROM=noreply@yoursite.com
HOSTINGER_EMAIL_USER=
HOSTINGER_EMAIL_PASS=

# --- ALTCHA captcha (production: set a real key) ---
# ALTCHA_HMAC_KEY=

# --- Optional: production CORS ---
# ALLOWED_ORIGINS=https://yoursite.com,https://www.yoursite.com

# --- Optional: storage provider ---
# VITE_STORAGE_PROVIDER=cloudinary

# --- Optional: analytics ---
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
